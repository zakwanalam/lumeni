<section class="min-h-screen bg-black text-white pt-32 pb-24 relative overflow-hidden">
  <div class="px-6 mx-auto lg:px-12 relative z-10">
    
    <!-- Hero / Header -->
    <div class="flex flex-col space-y-4 mb-24 max-w-4xl">
      <span class="readout-label">SYSTEM STATUS // ONLINE</span>
      <h1 class="text-6xl md:text-8xl font-bold font-display uppercase tracking-tightest leading-[0.9]">
        TECHNICAL<br>SUPPORT <span class="text-lumeni-accent">HUB</span>
      </h1>
    </div>

    <!-- Main Content Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-16 lg:gap-24 items-start">
      
      <!-- Left: Contact Form -->
      <div class="lg:col-span-7 flex flex-col space-y-12">
        <div class="flex flex-col space-y-4">
          <h2 class="text-3xl font-bold font-display uppercase italic">TRANSMIT INQUIRY</h2>
          <p class="text-lumeni-text-muted max-w-md text-sm leading-relaxed">
            Detailed technical requests are routed to our support team. Expect a response within 24 standard operating hours.
          </p>
        </div>

        {% form 'contact', class: 'flex flex-col space-y-8' %}
          {% if form.posted_successfully? %}
            <p class="p-6 bg-lumeni-accent bg-opacity-10 border border-lumeni-accent text-lumeni-accent text-sm font-bold uppercase tracking-technical">
              MESSAGE TRANSMITTED SUCCESSFULLY.
            </p>
          {% endif %}

          <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
            <div class="flex flex-col space-y-2">
              <label for="ContactFormName" class="readout-label text-[10px] opacity-40">IDENTIFIER NAME</label>
              <input type="text" id="ContactFormName" name="contact[name]" placeholder="FULL NAME" class="bg-transparent border border-white border-opacity-10 p-5 text-sm uppercase tracking-technical focus:outline-none focus:border-lumeni-accent transition-colors" required>
            </div>
            <div class="flex flex-col space-y-2">
              <label for="ContactFormEmail" class="readout-label text-[10px] opacity-40">DIGITAL MAIL</label>
              <input type="email" id="ContactFormEmail" name="contact[email]" placeholder="EMAIL ADDRESS" class="bg-transparent border border-white border-opacity-10 p-5 text-sm uppercase tracking-technical focus:outline-none focus:border-lumeni-accent transition-colors" required>
            </div>
          </div>

          <div class="flex flex-col space-y-2">
            <label for="ContactFormSubject" class="readout-label text-[10px] opacity-40">SUBJECT VECTOR</label>
            <select id="ContactFormSubject" name="contact[subject]" class="bg-black border border-white border-opacity-10 p-5 text-sm uppercase tracking-technical focus:outline-none focus:border-lumeni-accent transition-colors appearance-none">
              <option>PRODUCT TECH SPECS</option>
              <option>SHIPPING PROTOCOL</option>
              <option>WARRANTY CLAIM</option>
              <option>GENERAL INQUIRY</option>
            </select>
          </div>

          <div class="flex flex-col space-y-2">
            <label for="ContactFormMessage" class="readout-label text-[10px] opacity-40">MESSAGE PAYLOAD</label>
            <textarea id="ContactFormMessage" name="contact[body]" rows="6" placeholder="ENTER DETAILED DESCRIPTION" class="bg-transparent border border-white border-opacity-10 p-5 text-sm uppercase tracking-technical focus:outline-none focus:border-lumeni-accent transition-colors resize-none" required></textarea>
          </div>

          <button type="submit" class="bg-lumeni-accent text-black px-12 py-5 text-sm font-bold tracking-technical uppercase hover:opacity-80 transition-all duration-300 w-max">
            SUBMIT ENCRYPTED MESSAGE →
          </button>
        {% endform %}
      </div>

      <!-- Right: Info Sidebar -->
      <div class="lg:col-span-5 flex flex-col space-y-12">
        <div class="flex flex-col space-y-6">
          <span class="readout-label text-[10px] opacity-40">CORE CONNECTIVITY</span>
          
          <div class="space-y-4">
            <!-- Email Card -->
            <div class="p-8 bg-lumeni-surface border-l-2 border-lumeni-accent flex items-center gap-6">
               <div class="w-12 h-12 flex items-center justify-center bg-black border border-white border-opacity-5">
                 <svg class="w-5 h-5 text-lumeni-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" stroke-width="1.5"/></svg>
               </div>
               <div class="flex flex-col">
                 <span class="readout-label text-[8px] opacity-40">EMAIL UPLINK</span>
                 <p class="text-sm font-bold tracking-technical">SUPPORT@LUMENI.COM</p>
               </div>
            </div>

            <!-- Phone Card -->
            <div class="p-8 bg-lumeni-surface border-l-2 border-white border-opacity-10 flex items-center gap-6">
               <div class="w-12 h-12 flex items-center justify-center bg-black border border-white border-opacity-5">
                 <svg class="w-5 h-5 text-white opacity-40" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" stroke-width="1.5"/></svg>
               </div>
               <div class="flex flex-col">
                 <span class="readout-label text-[8px] opacity-40">DIRECT COMMS</span>
                 <p class="text-sm font-bold tracking-technical">+1 (888) 010-LUMENI</p>
               </div>
            </div>

            <!-- Location Card -->
            <div class="p-8 bg-lumeni-surface border-l-2 border-white border-opacity-10 flex items-center gap-6">
               <div class="w-12 h-12 flex items-center justify-center bg-black border border-white border-opacity-5">
                 <svg class="w-5 h-5 text-white opacity-40" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" stroke-width="1.5"/><path d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" stroke-width="1.5"/></svg>
               </div>
               <div class="flex flex-col">
                 <span class="readout-label text-[8px] opacity-40">COMMAND CENTER</span>
                 <p class="text-sm font-bold tracking-technical">NYC HQ // TECH DISTRICT</p>
               </div>
            </div>
          </div>
        </div>

        <!-- Sub Grid for Chat/FAQ -->
        <div class="grid grid-cols-2 gap-6">
           <a href="/pages/faq" class="p-8 bg-lumeni-surface border border-white border-opacity-5 hover:border-lumeni-accent transition-colors flex flex-col space-y-4">
              <svg class="w-6 h-6 text-lumeni-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" stroke-width="1.5"/></svg>
              <h4 class="text-xs font-bold font-display uppercase">FAQ BASE</h4>
           </a>
           <div class="p-8 bg-lumeni-surface border border-white border-opacity-5 hover:border-lumeni-accent transition-colors flex flex-col space-y-4 cursor-pointer">
              <svg class="w-6 h-6 text-white opacity-40" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" stroke-width="1.5"/></svg>
              <h4 class="text-xs font-bold font-display uppercase">LIVE CHAT</h4>
           </div>
        </div>
      </div>

    </div>

  </div>

  <!-- Ambient Backdrop -->
  <div class="absolute inset-0 pointer-events-none opacity-[0.05] select-none overflow-hidden">
     <div class="absolute top-0 right-0 w-[800px] h-[800px] bg-lumeni-accent rounded-full filter blur-[200px] translate-x-1/2 -translate-y-1/2"></div>
  </div>
</section>

{% schema %}
{
  "name": "Main Contact",
  "settings": []
}
{% endschema %}

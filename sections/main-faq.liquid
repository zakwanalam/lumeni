<section class="bg-black text-white pt-32 pb-24">
  <div class="px-6 mx-auto lg:px-12 max-w-[1440px]">
    
    <!-- Hero Header -->
    <div class="flex flex-col items-center text-center space-y-6 mb-24">
       <span class="readout-label text-lumeni-accent text-[10px]">SYSTEM SUPPORT  CORE V2</span>
       <h1 class="text-6xl md:text-8xl font-bold font-display uppercase tracking-tightest leading-none">
          HOW CAN WE <span class="text-lumeni-accent">ASSIST?</span>
       </h1>
       <div class="relative w-full max-w-2xl mt-8">
          <input type="text" placeholder="SEARCH PROTOCOLS, SHIPPING, OR TECH SPECS..." class="w-full bg-lumeni-surface border border-white border-opacity-10 py-6 px-12 text-[10px] font-bold font-display uppercase tracking-technical focus:outline-none focus:border-lumeni-accent transition-colors">
          <div class="absolute right-4 top-1/2 -translate-y-1/2 text-[8px] readout-label opacity-40">[ CMD + K ]</div>
       </div>
    </div>

    <!-- Tier 1 Services -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-32">
       {% assign service_titles = "LOGISTICS & DISPATCH,LIFETIME ASSURANCE,RETURN PROTOCOLS" | split: "," %}
       {% assign service_desc = "Global tracking, expedited freight options, and delivery status monitoring.,Technical warranty documentation, repair protocols, and coverage verification.,Streamlined exchange processing and automated return label generation." | split: "," %}
       {% for title in service_titles %}
          <div class="p-12 bg-lumeni-surface border border-white border-opacity-5 flex flex-col space-y-8 group hover:border-lumeni-accent transition-all duration-500">
             <div class="flex justify-between items-start">
                <div class="w-10 h-10 text-lumeni-accent">
                   {% if forloop.index == 1 %}
                      <svg fill="currentColor" viewBox="0 0 24 24"><path d="M20 8h-3V4H3c-1.1 0-2 .9-2 2v11h2c0 1.66 1.34 3 3 3s3-1.34 3-3h6c0 1.66 1.34 3 3 3s3-1.34 3-3h2v-5l-3-4zM6 18.5c-.83 0-1.5-.67-1.5-1.5s.67-1.5 1.5-1.5 1.5.67 1.5 1.5-.67 1.5-1.5 1.5zm13.5-9l1.96 2.5H17V9.5h2.5zm-1.5 9c-.83 0-1.5-.67-1.5-1.5s.67-1.5 1.5-1.5 1.5.67 1.5 1.5-.67 1.5-1.5 1.5z"/></svg>
                   {% elsif forloop.index == 2 %}
                      <svg fill="currentColor" viewBox="0 0 24 24"><path d="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4zm0 10.99h7c-.53 4.12-3.28 7.79-7 8.94V12H5V6.3l7-3.11v8.8z"/></svg>
                   {% else %}
                      <svg fill="currentColor" viewBox="0 0 24 24"><path d="M15 14l-4 4-4-4h3V4h2v10h3zM12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-3.31 0-6-2.69-6-6s2.69-6 6-6 6 2.69 6 6-2.69 6-6 6z"/></svg>
                   {% endif %}
                </div>
                <span class="readout-label text-[8px] opacity-40">PRD {{ forloop.index | plus: 100 }}</span>
             </div>
             <div class="flex flex-col space-y-4">
                <h3 class="text-xl font-bold font-display uppercase tracking-technical">{{ title }}</h3>
                <p class="text-[10px] text-lumeni-text-muted leading-relaxed uppercase tracking-widest opacity-60">{{ service_desc[forloop.index0] }}</p>
             </div>
             <a href="#" class="text-[9px] font-bold text-lumeni-accent tracking-technical uppercase flex items-center group-hover:translate-x-2 transition-transform">EXPLORE GUIDES →</a>
          </div>
       {% endfor %}
    </div>

    <!-- FAQ Accordion -->
    <div class="max-w-4xl mx-auto space-y-12">
       <div class="flex flex-col items-center space-y-4 mb-16">
          <div class="w-24 h-px bg-white bg-opacity-10"></div>
          <span class="readout-label text-[10px] opacity-40 italic">FREQUENTLY ASKED REPORTS</span>
       </div>

       <div class="space-y-4">
          {% assign questions = "WHAT IS THE TYPICAL DELIVERY DURATION?,DO YOU SHIP TO INTERNATIONAL COORDINATES?,HOW DO I EXECUTE A WARRANTY CLAIM?,CAN I MODIFY AN ACTIVE ORDER PROTOCOL?" | split: "," %}
          {% assign answers = "Standard global fulfillment typically concludes within 3-5 business days. Remote coordinates may require up to 10 days for final synchronization.,Global fulfillment is active for over 180 territories. Regional hubs ensure minimal transit latency. Duties are calculated at checkout to prevent delivery disruption.,Technical warranty documentation and repair protocols are included with every artifact. Initiate a claim via the Lifetime Assurance portal.,Order protocols can be modified within 60 minutes of initialization. Visit the Order Manifest in your account to request changes." | split: "," %}
          {% for q in questions %}
             <div class="border border-white border-opacity-5 bg-lumeni-surface overflow-hidden group faq-item">
                <button class="w-full p-8 flex items-center justify-between text-left focus:outline-none faq-trigger">
                   <div class="flex items-center space-x-6">
                      <span class="readout-label text-[8px] opacity-20">0{{ forloop.index }}.</span>
                      <span class="text-xs font-bold font-display uppercase tracking-technical group-hover:text-lumeni-accent transition-colors">{{ q }}</span>
                   </div>
                   <svg class="w-4 h-4 opacity-40 group-hover:opacity-100 transition-all transform faq-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M12 4v16m8-8H4" stroke-width="2"/></svg>
                </button>
                <div class="faq-content max-h-0 overflow-hidden transition-all duration-500 ease-in-out">
                   <div class="px-8 pb-8 pl-[4.5rem]">
                      <p class="text-[11px] text-lumeni-text-muted leading-loose uppercase tracking-widest opacity-80 max-w-2xl">
                         {{ answers[forloop.index0] }}
                      </p>
                   </div>
                </div>
             </div>
          {% endfor %}
       </div>
    </div>

    <script>
       document.addEventListener('DOMContentLoaded', () => {
          const triggers = document.querySelectorAll('.faq-trigger');
          triggers.forEach(trigger => {
             trigger.addEventListener('click', () => {
                const item = trigger.closest('.faq-item');
                const content = item.querySelector('.faq-content');
                const icon = item.querySelector('.faq-icon');
                
                const isOpen = !content.classList.contains('max-h-0');
                
                // Close others
                document.querySelectorAll('.faq-content').forEach(c => c.classList.add('max-h-0'));
                document.querySelectorAll('.faq-icon').forEach(i => i.classList.remove('rotate-45'));
                
                if (!isOpen) {
                   content.classList.remove('max-h-0');
                   content.style.maxHeight = content.scrollHeight + 'px';
                   icon.classList.add('rotate-45');
                } else {
                   content.classList.add('max-h-0');
                   content.style.maxHeight = '0';
                   icon.classList.remove('rotate-45');
                }
             });
          });
       });
    </script>

    <!-- Contact Tiles -->
    {% comment %} <div class="grid grid-cols-1 md:grid-cols-4 gap-4 mt-32">
       {% assign contact_tiles = "LIVE CHAT,EMAIL QUERY,VOICE COMMAND,B2B PORTAL" | split: "," %}
       {% for tile in contact_tiles %}
          <div class="p-8 bg-lumeni-surface border border-white border-opacity-5 flex flex-col space-y-6">
             <div class="w-8 h-8 rounded bg-white bg-opacity-5 flex items-center justify-center">
                <div class="w-3 h-3 bg-lumeni-accent"></div>
             </div>
             <div class="flex flex-col space-y-1">
                <span class="text-xs font-bold font-display uppercase">{{ tile | replace: ' ', '_' }}</span>
                <span class="text-[8px] readout-label opacity-20">{% if forloop.index == 1 %}STATUS: ONLINE{% else %}REPLY < 12 HOURS{% endif %}</span>
             </div>
             <button class="w-full py-4 border border-white border-opacity-10 text-[9px] font-bold tracking-technical uppercase hover:bg-white hover:text-black transition-all">
                {% if forloop.index == 1 %}INITIATE SESSION{% else %}OPEN TICKET{% endif %}
             </button>
          </div>
       {% endfor %}
    </div> {% endcomment %}

    <!-- Bottom CTA -->
    <div class="mt-48 flex flex-col items-center text-center space-y-12 border-t border-white border-opacity-5 pt-32">
       <div class="w-12 h-1 bg-lumeni-accent"></div>
       <div class="space-y-6">
          <h2 class="text-5xl md:text-7xl font-bold font-display uppercase tracking-tightest leading-none">STILL REQUIRE TECHNICAL <span class="text-lumeni-accent">CLARIFICATION?</span></h2>
          <p class="text-sm text-lumeni-text-muted uppercase tracking-widest max-w-2xl mx-auto leading-relaxed">Our engineering and logistics teams are standing by to resolve any operational discrepancies.</p>
       </div>
       <div class="flex flex-col md:flex-row gap-6">
          <button class="bg-lumeni-accent text-black px-12 py-5 text-xs font-bold tracking-technical uppercase">CONTACT THE CORE</button>
          <button class="border border-white border-opacity-10 px-12 py-5 text-xs font-bold tracking-technical uppercase hover:bg-white hover:text-black transition-all">DOWNLOAD DOCUMENTATION ↓</button>
       </div>
    </div>

  </div>
</section>

{% schema %}
{
  "name": "Main FAQ",
  "settings": []
}
{% endschema %}

<section class="bg-black text-white min-h-screen pt-32 pb-24">
  <div class="px-6 mx-auto lg:px-12 max-w-[1440px]">
    
    <!-- Search Header -->
    <div class="flex flex-col space-y-4 mb-16 border-b border-white border-opacity-10 pb-12">
       <div class="flex justify-between items-end">
          <div class="flex flex-col space-y-2">
             <span class="readout-label text-lumeni-accent text-[10px]">SEARCH DATABASE // QUERY ALPHA</span>
             <h1 class="text-6xl md:text-8xl font-bold font-display uppercase tracking-tightest leading-none">
                "{{ search.terms | upcase | replace: '_', ' ' }}"
             </h1>
          </div>
          <div class="hidden md:block">
             <span class="readout-label text-[10px] opacity-40 italic">[ {{ search.results_count }} ] RESULTS LOCATED IN MAINFRAME</span>
          </div>
       </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-16">
       
       <!-- Sidebar -->
       <aside class="lg:col-span-3 space-y-12">
          <form id="SearchFiltersForm" action="{{ routes.search_url }}">
             <input type="hidden" name="q" value="{{ search.terms }}">
             
             <div class="space-y-12">
                {%- for filter in search.filters -%}
                   {%- case filter.type -%}
                      {%- when 'list' or 'boolean' -%}
                         <div class="flex flex-col space-y-6">
                            <span class="readout-label text-[10px] text-lumeni-accent uppercase">{{ filter.label | replace: '_', ' ' }}</span>
                            <div class="flex flex-col space-y-4">
                               {%- for value in filter.values -%}
                                  <label class="flex items-center space-x-3 cursor-pointer group">
                                     <input type="checkbox"
                                            name="{{ value.param_name }}"
                                            value="{{ value.value }}"
                                            {% if value.active %}checked{% endif %}
                                            {% if value.count == 0 and value.active == false %}disabled{% endif %}
                                            class="w-4 h-4 bg-black border border-white border-opacity-20 rounded-none checked:bg-lumeni-accent checked:border-lumeni-accent appearance-none transition-all cursor-pointer filter-checkbox">
                                     <span class="text-[11px] font-bold font-display uppercase tracking-technical group-hover:text-lumeni-accent transition-colors {% if value.count == 0 and value.active == false %}opacity-30 pointer-events-none{% endif %}">
                                        {{ value.label | replace: '_', ' ' }} ({{ value.count }})
                                     </span>
                                  </label>
                               {%- endfor -%}
                            </div>
                         </div>

                      {%- when 'price_range' -%}
                         <div class="flex flex-col space-y-6">
                            <span class="readout-label text-[10px] text-lumeni-accent uppercase">PRICE RANGE</span>
                            <div class="flex flex-col space-y-4">
                               <div class="flex items-center space-x-4">
                                  <div class="flex-1 flex flex-col space-y-2">
                                     <label class="readout-label text-[8px] opacity-40">MIN</label>
                                     <div class="relative">
                                        <span class="absolute left-4 top-1/2 -translate-y-1/2 text-lumeni-accent text-[8px] opacity-40">$</span>
                                        <input name="{{ filter.min_value.param_name }}"
                                               type="number"
                                               placeholder="0"
                                               {%- if filter.min_value.value -%}value="{{ filter.min_value.value | money_without_currency | replace: ',', '' }}"{%- endif -%}
                                               class="w-full bg-black border border-white border-opacity-10 py-3 pl-8 pr-4 text-[10px] font-bold font-display uppercase tracking-technical focus:border-lumeni-accent transition-all filter-input">
                                     </div>
                                  </div>
                                  <div class="pt-4 text-lumeni-accent opacity-20">—</div>
                                  <div class="flex-1 flex flex-col space-y-2">
                                     <label class="readout-label text-[8px] opacity-40">MAX</label>
                                     <div class="relative">
                                        <span class="absolute left-4 top-1/2 -translate-y-1/2 text-lumeni-accent text-[8px] opacity-40">$</span>
                                        <input name="{{ filter.max_value.param_name }}"
                                               type="number"
                                               placeholder="{{ filter.range_max | money_without_currency | replace: ',', '' }}"
                                               {%- if filter.max_value.value -%}value="{{ filter.max_value.value | money_without_currency | replace: ',', '' }}"{%- endif -%}
                                               class="w-full bg-black border border-white border-opacity-10 py-3 pl-8 pr-4 text-[10px] font-bold font-display uppercase tracking-technical focus:border-lumeni-accent transition-all filter-input">
                                     </div>
                                  </div>
                               </div>
                            </div>
                         </div>
                   {%- endcase -%}
                {%- endfor -%}

                <!-- Sort Switch -->
                <div class="flex flex-col space-y-6 pt-6 border-t border-white border-opacity-5">
                   <span class="readout-label text-[10px] text-lumeni-accent">SORT SEQUENCE</span>
                   <div class="relative group">
                      <select name="sort_by" class="w-full bg-black border border-white border-opacity-10 py-4 px-6 text-[10px] font-bold font-display uppercase tracking-technical appearance-none cursor-pointer focus:outline-none focus:border-lumeni-accent filter-select">
                         {%- for option in search.sort_options -%}
                            <option value="{{ option.value }}" {% if option.value == search.sort_by %}selected{% endif %}>{{ option.name | upcase }}</option>
                         {%- endfor -%}
                      </select>
                      <div class="absolute right-4 top-1/2 -translate-y-1/2 pointer-events-none opacity-40 group-hover:opacity-100 transition-opacity">
                         <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M19 9l-7 7-7-7" stroke-width="2"/></svg>
                      </div>
                   </div>
                </div>

                <!-- Clear Button -->
                {%- if search.filters.size > 0 -%}
                   <a href="{{ routes.search_url }}?q={{ search.terms }}" class="block text-center py-4 border border-white border-opacity-10 text-[9px] font-bold tracking-technical uppercase hover:bg-white hover:text-black transition-all">
                      RESET ALL FILTERS
                   </a>
                {%- endif -%}
             </div>
          </form>
       </aside>

       <script>
          document.addEventListener('DOMContentLoaded', () => {
             const form = document.querySelector('#SearchFiltersForm');
             if(!form) return;

             const handleChange = () => {
                const formData = new FormData(form);
                const queryParams = new URLSearchParams(formData).toString();
                window.location.href = `${window.location.pathname}?${queryParams}`;
             };

             form.querySelectorAll('.filter-checkbox').forEach(box => {
                box.addEventListener('change', handleChange);
             });

             form.querySelector('.filter-select')?.addEventListener('change', handleChange);

             let timer;
             form.querySelectorAll('.filter-input').forEach(input => {
                input.addEventListener('input', () => {
                   clearTimeout(timer);
                   timer = setTimeout(handleChange, 1500);
                });
             });
          });
       </script>

       <!-- Results Content -->
       <main class="lg:col-span-9">
          {% if search.results_count > 0 %}
             <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-16">
                {% for item in search.results %}
                   {% if item.object_type == 'product' %}
                      <!-- Standard Card -->
                      <a href="{{ item.url }}" class="flex flex-col space-y-6 group">
                         <div class="aspect-[4/5] bg-lumeni-surface overflow-hidden relative">
                            <img src="{{ item.featured_image | img_url: '800x' }}" class="w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all duration-700">
                            {% if item.available == false %}
                               <div class="absolute top-4 left-4">
                                  <span class="bg-red-500 text-white text-[8px] font-bold px-2 py-1 uppercase">DEPLETED</span>
                               </div>
                            {% endif %}
                         </div>
                         <div class="flex flex-col space-y-2">
                            <div class="flex justify-between items-center">
                               <span class="readout-label text-[8px] opacity-40">ARTIFACT // 0{{ forloop.index }}</span>
                               <span class="text-xs font-bold text-lumeni-accent">{{ item.price | money }}</span>
                            </div>
                            <h3 class="text-sm font-bold font-display uppercase tracking-technical group-hover:text-lumeni-accent transition-colors italic">
                               {{ item.title | replace: '_', ' ' }}
                            </h3>
                            <div class="flex items-center space-x-4 opacity-40">
                               <span class="text-[8px] readout-label">MISSION READY</span>
                               <span class="text-[12px] opacity-20">•</span>
                               <span class="text-[8px] readout-label">{{ item.vendor | upcase }}</span>
                            </div>
                         </div>
                      </a>

                      <!-- Highlighted Card (Every 4th) -->
                      {% if forloop.index == 4 %}
                         <div class="md:col-span-3 lg:col-span-2 grid grid-cols-1 md:grid-cols-2 bg-lumeni-surface group mt-8">
                            <div class="aspect-square overflow-hidden border-r border-white border-opacity-5">
                               <img src="{{ item.featured_image | img_url: '1000x' }}" class="w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all duration-700">
                            </div>
                            <div class="p-12 flex flex-col justify-center space-y-8">
                               <div class="flex flex-col space-y-4">
                                  <span class="readout-label text-[10px] text-lumeni-accent">MASTERPIECE COLLECTION</span>
                                  <h3 class="text-3xl font-bold font-display uppercase tracking-tightest leading-none">{{ item.title | upcase }}</h3>
                                  <p class="text-[10px] text-lumeni-text-muted uppercase leading-relaxed tracking-widest opacity-60">{{ item.description | strip_html | truncate: 150 }}</p>
                               </div>
                               <a href="{{ item.url }}" class="bg-lumeni-accent text-center text-black py-4 px-8 text-[10px] font-bold tracking-technical uppercase self-start hover:tracking-widest transition-all">
                                  VIEW SPECIFICATIONS
                               </a>
                            </div>
                         </div>
                      {% endif %}

                   {% endif %}
                {% endfor %}
             </div>

             <!-- Pagination Status -->
             {% if search.results_count > 8 %}
                <div class="flex flex-col items-center space-y-8 pt-12 border-t border-white border-opacity-5">
                   <div class="flex flex-col items-center space-y-4 w-full max-w-md">
                      <div class="w-full h-1 bg-white bg-opacity-10 relative overflow-hidden">
                         <div class="absolute inset-y-0 left-0 bg-lumeni-accent w-full"></div>
                      </div>
                      <span class="readout-label text-[9px] opacity-40">SYSTEM LOAD COMPLETE // {{ search.results_count }} ARTIFACTS LOCATED</span>
                   </div>
                </div>
             {% endif %}

          {% else %}
             <div class="flex flex-col items-center justify-center py-48 text-center bg-lumeni-surface border border-white border-opacity-5">
                <span class="readout-label text-lumeni-accent mb-6">DATABASE ERROR // 404</span>
                <h2 class="text-4xl font-bold font-display uppercase mb-4">No Matches Located</h2>
                <p class="text-xs text-lumeni-text-muted uppercase tracking-widest leading-loose max-w-sm mb-12">The requested query did not match any stored artifacts in the mainframe.</p>
                <a href="/collections/all" class="bg-lumeni-accent text-black px-12 py-5 text-xs font-bold tracking-technical uppercase">RE-INITIALIZE SEARCH</a>
             </div>
          {% endif %}
       </main>

    </div>
  </div>
</section>

{% schema %}
{
  "name": "High-Fidelity Search",
  "settings": []
}
{% endschema %}

<header class="fixed top-0 left-0 w-full z-[80] bg-black border-b border-white border-opacity-5" id="Header">
  <div class="px-6 mx-auto lg:px-12">
    <div class="flex items-center justify-between h-20 md:h-24">
      
      <!-- Brand Logo -->
      <div class="flex-shrink-0">
        <a href="/" class="text-xl font-bold tracking-technical font-display text-lumeni-accent uppercase">
          LUMENI
        </a>
      </div>

      <!-- Navigation System -->
      <nav class="hidden space-x-10 lg:flex absolute left-1/2 -translate-x-1/2">
        {% for link in section.settings.menu.links %}
          {% if link.title contains 'Journal' or link.title contains 'JOURNAL' %}{% continue %}{% endif %}
          <a href="{{ link.url }}" class="text-[11px] font-bold tracking-technical uppercase transition-opacity duration-300 text-lumeni-text hover:opacity-50">
            {{ link.title }}
          </a>
        {% endfor %}
        <!-- Tech Artifact Links -->
        <a href="/pages/philosophy" class="text-[11px] font-bold tracking-technical uppercase transition-opacity duration-300 text-lumeni-accent hover:opacity-50">PHILOSOPHY</a>
        <a href="/pages/faq" class="text-[11px] font-bold tracking-technical uppercase transition-opacity duration-300 text-lumeni-text hover:opacity-50">FAQ</a>
      </nav>

      <!-- Utility Icons -->
      <div class="flex items-center space-x-8">
        <button class="text-lumeni-text hover:text-lumeni-accent transition-colors" id="OpenSearch">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
        </button>

        <a href="/account/login" class="text-lumeni-text hover:text-lumeni-accent transition-colors hidden md:block">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path></svg>
        </a>

        <button class="relative flex items-center text-lumeni-text hover:text-lumeni-accent transition-colors" id="OpenCart">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"></path></svg>
          {% if cart.item_count > 0 %}
            <span class="absolute -top-2 -right-2 bg-lumeni-accent text-lumeni-lowest text-[9px] font-bold w-3.5 h-3.5 flex items-center justify-center rounded-full">
              {{ cart.item_count }}
            </span>
          {% endif %}
        </button>

        <!-- Mobile Toggle -->
        <button class="lg:hidden text-lumeni-text hover:text-lumeni-accent transition-colors" id="OpenMobileMenu">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6h16M4 12h16M4 18h16"></path></svg>
        </button>
      </div>
    </div>
  </div>
</header>

<style>
  #Header {
    background-color: black;
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
  }
</style>

{% schema %}
{
  "name": "Lumeni Header",
  "settings": [
    {
      "type": "link_list",
      "id": "menu",
      "label": "Main Menu",
      "default": "main-menu"
    }
  ]
}
{% endschema %}
